# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.
# In production (GitHub Actions / Hostinger), set these as environment variables or GitHub Secrets.

# LiteLLM proxy URL
LITELLM_URL=http://your-litellm-host:4000/v1/chat/completions

# API key for LiteLLM (set as GitHub Secret: LITELLM_KEY)
LITELLM_KEY=sk-your-key-here

# Model to use (optional, defaults to gpt-4o)
LITELLM_MODEL=gpt-4o
